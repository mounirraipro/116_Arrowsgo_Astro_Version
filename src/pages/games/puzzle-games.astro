---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { externalGames } from "@/data/externalGames";

const puzzleGames = externalGames.filter((game) => ["Pathing", "Spatial", "Grid", "Numbers"].includes(game.category));
---

<BaseLayout
  title="Puzzle Games Online"
  description="Play Remove All Arrows on Arrows Go and related puzzle games online, including pathing, spatial, grid, and number browser games."
  seo={{ path: "/games/puzzle-games", seoTitle: "Puzzle Games Online - Play Remove All Arrows and Related Games" }}
>
  <section class="games-directory">
    <header class="games-directory-hero">
      <div>
        <h1>Puzzle games online.</h1>
        <p>Remove All Arrows is the main puzzle game on this site, and these related games keep the same quick-session spirit through path planning, grid logic, or space management.</p>
      </div>
      <a class="games-directory-action" href="/play/"><span></span>Play Remove All Arrows</a>
    </header>

    <section class="games-directory-main" aria-labelledby="puzzle-games-list">
      <div class="games-directory-intro">
        <h2 id="puzzle-games-list">Puzzle-friendly picks</h2>
        <p>Choose a game when you want short decisions, readable rules, and no download.</p>
      </div>
      <div class="games-directory-list">
        {puzzleGames.map((game, index) => (
          <a class:list={["games-directory-row", game.accentClass]} href={`/games/${game.slug}/`}>
            <span class="games-directory-number">{String(index + 1).padStart(2, "0")}</span>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="320" height="180" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <h3>{game.title}</h3>
              <p>{game.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
