---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { externalGames } from "@/data/externalGames";

const timingGames = externalGames.filter((game) => ["Pathing", "Aim", "Spatial"].includes(game.category));
---

<BaseLayout
  title="Timing Games Online"
  description="Play Arrows Go and related timing games online, including pathing, aiming, and spatial browser games that reward clean decisions."
  seo={{ path: "/games/timing-games", seoTitle: "Timing Games Online - Play Arrows Go and Related Games" }}
>
  <section class="games-directory">
    <header class="games-directory-hero">
      <div>
        <h1>Timing games online.</h1>
        <p>Arrows Go is the main timing game on this site, and these related games keep the same quick-session spirit through pathing, aiming, or space management.</p>
      </div>
      <a class="games-directory-action" href="/play/"><span></span>Play Arrows Go</a>
    </header>

    <section class="games-directory-main" aria-labelledby="timing-games-list">
      <div class="games-directory-intro">
        <h2 id="timing-games-list">Timing-friendly picks</h2>
        <p>Choose a game when you want short decisions, visible feedback, and no download.</p>
      </div>
      <div class="games-directory-list">
        {timingGames.map((game, index) => (
          <a class:list={["games-directory-row", game.accentClass]} href={`/games/${game.slug}/`}>
            <span class="games-directory-number">{String(index + 1).padStart(2, "0")}</span>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="320" height="180" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <h3>{game.title}</h3>
              <p>{game.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
