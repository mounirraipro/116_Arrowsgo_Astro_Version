---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { externalGames } from "@/data/externalGames";
import { brandAccentClass } from "@/data/accentClasses";

const featuredGames = [
  {
    href: "/play/",
    title: "Remove All Arrows Online",
    shortTitle: "Remove Arrows",
    category: "Main game",
    description: "Launch arrows in sequence, avoid collisions, and clear every board in your browser.",
    thumbnail: "/game-thumbs/arrows-go.svg",
    accentClass: brandAccentClass,
  },
  ...externalGames.slice(0, 3).map((game) => ({
    href: `/games/${game.slug}/`,
    title: game.title,
    shortTitle: game.shortTitle,
    category: game.category,
    description: game.description,
    thumbnail: game.thumbnail,
    accentClass: game.accentClass,
  })),
];

const directoryGames = [
  {
    href: "/play/",
    title: "Remove All Arrows Online",
    shortTitle: "Remove Arrows",
    category: "Arrow puzzle",
    description: "The main Arrows Go experience with launch order, collision avoidance, and quick browser puzzle levels.",
    thumbnail: "/game-thumbs/arrows-go.svg",
    accentClass: brandAccentClass,
  },
  ...externalGames.map((game) => ({
    href: `/games/${game.slug}/`,
    title: game.title,
    shortTitle: game.shortTitle,
    category: game.category,
    description: game.description,
    thumbnail: game.thumbnail,
    accentClass: game.accentClass,
  })),
];
---

<BaseLayout title="Free Online Games" description="Play Remove All Arrows on Arrows Go and related free browser games focused on logic, pathing, aiming, grid planning, and quick no-download sessions.">
  <section class="games-directory">
    <header class="games-directory-hero">
      <div>
        <h1>Free browser games.</h1>
        <p>Play Remove All Arrows on Arrows Go and a focused library of logic, pathing, aiming, spatial, number, and focus games. No downloads, no account setup, just clean browser play.</p>
      </div>
      <a class="games-directory-action" href="/play/"><span></span>Play Arrows Go</a>
    </header>

    <div class="games-feature-rail" aria-label="Featured games">
      {featuredGames.map((game, index) => (
        <a class:list={["games-feature-link", game.accentClass]} href={game.href}>
          <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="640" height="360" loading="lazy" />
          <div>
            <span>{game.category}</span>
            <strong>{game.shortTitle}</strong>
          </div>
          <small>{index === 0 ? "Start here" : "Related pick"}</small>
        </a>
      ))}
    </div>

    <section class="games-directory-main" aria-labelledby="games-directory-title">
      <div class="games-directory-intro">
        <h2 id="games-directory-title">Choose a game</h2>
        <p>{directoryGames.length} browser games selected for quick breaks, board reading, and low-friction play.</p>
      </div>

      <div class="games-directory-list">
        {directoryGames.map((game, index) => (
          <a class:list={["games-directory-row", game.accentClass]} href={game.href}>
            <span class="games-directory-number">{String(index + 1).padStart(2, "0")}</span>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="320" height="180" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <h3>{game.title}</h3>
              <p>{game.description}</p>
            </div>
            <span class="games-directory-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                <path d="M7 17L17 7M9 7h8v8" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="games-guide-strip" aria-labelledby="games-library-guide">
      <h3 id="games-library-guide">Game library guide</h3>
      <div>
        <article>
          <h3>Free browser games in one place</h3>
          <p>The games library brings together Arrows Go and a focused set of free online games that work directly in the browser. The goal is to keep every game easy to open, easy to understand, and useful for quick sessions without downloads or account setup.</p>
        </article>
        <article>
          <h3>How to choose a game</h3>
          <p>Choose Remove All Arrows when you want launch-order logic, Brain Line Connect for path planning, Bubble Shooter for aiming, Block Puzzle for spatial organization, 2048 Merge Blocks for number planning, and Word Search for calmer scanning practice.</p>
        </article>
        <article>
          <h3>Why no-download play matters</h3>
          <p>Browser games remove friction. You can open a page, play immediately, and leave without installing software. That matters for players on shared computers, mobile devices, school laptops, or short work breaks.</p>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>
