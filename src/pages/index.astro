---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articles } from "@/data/articles";
import { externalGames } from "@/data/externalGames";
import { playFocusAreas } from "@/data/gameData";
import { siteConfig } from "@/data/siteConfig";
import { brandAccentClass, getFocusAccentClass } from "@/data/accentClasses";

const recentPosts = articles.slice(0, 3);
const mainGame = {
  href: "/play/",
  title: "Remove All Arrows Online",
  shortTitle: "Remove Arrows",
  category: "Now playing",
  thumbnail: "/game-thumbs/arrows-go.svg",
  accent: "#2563eb",
  accentClass: brandAccentClass,
};
const homeBentoGames = [
  mainGame,
  ...externalGames.map((game) => ({
    href: `/games/${game.slug}/`,
    title: game.title,
    shortTitle: game.shortTitle,
    category: game.category,
    thumbnail: game.thumbnail,
    accent: game.accent,
    accentClass: game.accentClass,
  })),
].slice(0, 8);
const homeBentoLeft = homeBentoGames.slice(0, 4);
const homeBentoRight = homeBentoGames.slice(4, 8);

const faqItems = [
  ["What is Arrows Go?", "Arrows Go is a free browser puzzle site where you can play Remove All Arrows online."],
  ["How do you play Remove All Arrows?", "Click or tap arrows to launch them in their pointed direction. Clear every arrow without letting a launched arrow collide with another one."],
  ["Is Arrows Go free?", "Yes. Remove All Arrows is free to play through Arrows Go with no download, no account, and no app install required."],
  ["Does Arrows Go work on mobile?", "Yes. The embedded Playgama game supports browser play on desktop and mobile devices where the iframe is available."],
  ["Why is the iframe loaded through /game/index.html?", "The local wrapper keeps the main Astro site route stable while loading the hosted HTML5 game inside the playable frame."],
];

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "VideoGame",
    name: "Remove All Arrows",
    alternateName: ["Arrows Go Online", "ArrowsGo", "Arrow puzzle game"],
    url: `${siteConfig.siteUrl}/`,
    image: new URL(siteConfig.defaultOgImage, siteConfig.siteUrl).href,
    description: siteConfig.description,
    applicationCategory: "Game",
    gamePlatform: ["Web browser", "Desktop", "Mobile", "Tablet"],
    genre: ["Puzzle", "Logic", "Brain game", "Arrow game"],
    operatingSystem: "Any modern browser",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.publisherName,
      url: siteConfig.siteUrl,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(([question, answer]) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} structuredData={homeStructuredData}>
  <section class="hero-play">
    <div class="home-game-lobby">
      <div class="game-bento-grid game-bento-grid-side" aria-label="Games you can play">
        {homeBentoLeft.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={game.href}>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="640" height="360" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
      <div class="hero-game">
        <iframe src="/game/index.html" title="Play Remove All Arrows" loading="eager"></iframe>
      </div>
      <div class="game-bento-grid game-bento-grid-side" aria-label="More games">
        {homeBentoRight.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={game.href}>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="640" height="360" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
    <div class="hero-copy">
      <div class="hero-copy-main">
        <p class="eyebrow">Instant play</p>
        <h1>Remove All Arrows Online</h1>
        <p>Play Remove All Arrows free on Arrows Go. Launch each arrow in the right order, avoid collisions, and clear the board with no download and no account.</p>
        <a class="text-link hero-note" href="/how-to-play/">Learn the rules</a>
      </div>
      <div class="hero-play-panel">
        <div class="hero-panel-top">
          <span>Ready in browser</span>
          <strong>Start a quick puzzle.</strong>
        </div>
        <div class="hero-actions">
          <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play Full Screen</a>
          <a class="secondary-action" href="/how-to-play/">How To Play</a>
        </div>
        <dl class="stat-row">
          <div><dt>0</dt><dd>Downloads</dd></div>
          <div><dt>4</dt><dd>Core Skills</dd></div>
          <div><dt>{articles.length}</dt><dd>Guides</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="home-section home-search-intent">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">Arrows Go guide</p>
        <h2>Play the arrow logic puzzle game.</h2>
      </div>
      <p>Remove All Arrows turns one simple idea into a tight browser challenge: read the board, launch arrows in sequence, and avoid every collision.</p>
    </div>
    <div class="process-strip">
      <article>
        <span>Free</span>
        <h3>Browser play</h3>
        <p>Open <a href="/play/">Arrows Go online</a> and start instantly. The game runs in the browser with no app store, installer, or sign-up flow.</p>
      </article>
      <article>
        <span>Order</span>
        <h3>Launch sequence</h3>
        <p>Trace each straight path and choose which arrow should leave the board first.</p>
      </article>
      <article>
        <span>Focus</span>
        <h3>Collision resets</h3>
        <p>Each attempt is short enough to learn from. Notice the blocked path, restart, and make the next sequence cleaner.</p>
      </article>
      <article>
        <span>Learn</span>
        <h3>Helpful paths</h3>
        <p>Use the <a href="/how-to-play/">how to play guide</a>, read <a href="/strategy/">strategy tips</a>, or explore <a href="/games/">related games</a>.</p>
      </article>
    </div>
  </section>

  <section class="home-section home-authority">
    <div class="authority-panel">
      <div class="home-section-head">
        <p class="eyebrow">Puzzle context</p>
        <h3>Built for quick directional decisions.</h3>
        <p>
          Keep <a class="site-identity-link" href="/"><strong>www.arrowsgo.com</strong></a> as your route back to the free browser puzzle, then explore the classic logic ideas behind sequence solving and spatial reasoning.
        </p>
      </div>
      <div class="authority-links" aria-label="External puzzle references">
        <a href="https://en.wikipedia.org/wiki/Puzzle_video_game" target="_blank" rel="noopener noreferrer">
          <span>Wikipedia</span>
          <strong>Puzzle game context</strong>
          <small>How rule-based puzzle games create readable challenges.</small>
        </a>
        <a href="https://en.wikipedia.org/wiki/Logic_puzzle" target="_blank" rel="noopener noreferrer">
          <span>Wikipedia</span>
          <strong>Logic puzzle</strong>
          <small>The reasoning concept behind board-clearing challenges.</small>
        </a>
        <a href="https://www.youtube.com/results?search_query=remove+all+arrows+gameplay" target="_blank" rel="noopener noreferrer">
          <span>YouTube</span>
          <strong>Gameplay videos</strong>
          <small>Watch arrow puzzle and board-clearing examples.</small>
        </a>
      </div>
    </div>
  </section>

  <section class="home-section home-worlds">
    <div class="home-section-head">
      <p class="eyebrow">Core loop</p>
      <h3>Four skills that shape every run.</h3>
      <p>Short attempts make each skill easy to practice one at a time.</p>
    </div>
    <div class="world-showcase">
      <a class:list={["world-feature", getFocusAccentClass(playFocusAreas[0].name)]} href="/strategy/">
        <img src="/game-thumbs/arrows-go.svg" alt="Arrows Go direction control preview" width="640" height="360" loading="lazy" />
        <div>
          <span>{playFocusAreas[0].name}</span>
          <strong>Clear the first safe arrow.</strong>
          <small>{playFocusAreas[0].description}</small>
        </div>
      </a>
      <div class="world-stack">
        {playFocusAreas.slice(1).map((focus) => (
          <a class:list={["world-card", getFocusAccentClass(focus.name)]} href="/strategy/">
            <img src="/game-thumbs/arrows-go.svg" alt={`${focus.name} Arrows Go preview`} width="640" height="360" loading="lazy" />
            <div>
              <span>{focus.name}</span>
              <small>{focus.description}</small>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section home-process">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">How it works</p>
        <h3>Read. Sequence. Launch. Clear.</h3>
      </div>
      <p>Four steps from first scan to a cleaner board.</p>
    </div>
    <div class="process-strip">
      <article><span>01</span><h3>Read</h3><p>Scan the full board before choosing a move.</p></article>
      <article><span>02</span><h3>Sequence</h3><p>Pick the arrow that opens the safest next path.</p></article>
      <article><span>03</span><h3>Launch</h3><p>Send one arrow straight toward its exit without collisions.</p></article>
      <article><span>04</span><h3>Clear</h3><p>Repeat until every arrow leaves the board.</p></article>
    </div>
  </section>

  <section class="home-section home-blog">
    <div class="blog-editorial">
      <div class="home-section-head">
        <p class="eyebrow">From the blog</p>
        <h3>Sharper arrow puzzle strategy.</h3>
        <p>Long-form reads for better launch order, cleaner clears, and mobile play.</p>
        <a class="text-link" href="/blog/">Browse all articles</a>
      </div>
      <div class="blog-board">
        <a class="editorial-card editorial-card-featured" href={`/blog/${recentPosts[0].slug}/`}>
          <span>{recentPosts[0].category}</span>
          <h3>{recentPosts[0].title}</h3>
          <p>{recentPosts[0].description}</p>
          <small>{recentPosts[0].readTime}</small>
        </a>
        <div class="article-rail">
          {recentPosts.slice(1).map((post) => (
            <a class="editorial-card editorial-card-row" href={`/blog/${post.slug}/`}>
              <span>{post.category}</span>
              <h3>{post.title}</h3>
              <small>{post.readTime}</small>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-faq">
    <div class="faq-layout">
      <div class="faq-cardlet">
        <p class="eyebrow">FAQ</p>
        <h3>Quick answers.</h3>
        <p>Need the short version before playing?</p>
      </div>
      <div class="faq-list" data-faq-list>
        {faqItems.map(([question, answer]) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div>
      <p class="eyebrow">Ready?</p>
      <h3>Open Arrows Go and clear a board.</h3>
    </div>
    <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play Remove All Arrows</a>
  </section>

  <script is:inline>
    (() => {
      document.querySelectorAll("[data-faq-list]").forEach((list) => {
        list.querySelectorAll("details").forEach((item) => {
          item.addEventListener("toggle", () => {
            if (!item.open) return;
            list.querySelectorAll("details[open]").forEach((other) => {
              if (other !== item) other.open = false;
            });
          });
        });
      });
    })();
  </script>
</BaseLayout>
